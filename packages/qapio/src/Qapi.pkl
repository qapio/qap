open class QapiBase {
  Qapi: String
  Props: Any = new Dynamic {}
}
open class Qapi extends QapiBase {
  Endpoint: String
}

open class Stage extends Qapi {
  Kind: "Source" | "Flow" | "Sink"
  Operators: List<Operator>

}

open class Operator extends QapiBase {

}

