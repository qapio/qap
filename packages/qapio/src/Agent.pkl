module Tdip.Qapio.Assistant.Agent
extends "Qaplet.pkl"
import "QapiTemplate.pkl"
import "pkl:reflect"

import "package://pkg.pkl-lang.org/pkl-pantry/org.openapis.v3.contrib@1.1.0#/SchemaGenerator.pkl"

class AiTool {
  Name: String
  Description: String?
  Qapi: QapiTemplate | String
}

Instructions: String = ""
ResponseFormat: Class?
Tools: Listing<AiTool>

function GetSchema(m: QapiTemplate) =
  let (schema = SchemaGenerator.generate(m))
    (schema) {
      properties = schema.properties.toMap().entries.filter((t) -> t.key != "Qapi").toMap((t) -> t.key, (t) -> t.value).toMap().toMapping()
      required = schema.required.toList().filter((t) -> t != "Qapi").toListing()
    }

local function GetQapi(c: QapiTemplate | Uri) =
  if (c == null)
    null
    else if (c is QapiTemplate)
    new Dynamic {
      Uri = reflect.Module(c).uri
      RequestSchema = GetSchema(c)} else
    new Dynamic {
      Uri = c
      ResponseFormat = null
    }

output {
  renderer = new JsonRenderer {
    converters {
      [Class] = (c) -> if (c != null) SchemaGenerator.generate(c) else null
      ["Qapi"] = (c) -> GetQapi(c)
    }
  }
}