module Tdip.Qapio.Assistant.Agent
extends "Qaplet.pkl"
import "package://pkg.pkl-lang.org/pkl-pantry/org.openapis.v3.contrib@1.1.0#/SchemaGenerator.pkl"

Instructions: String = ""
ResponseFormat: Class?

output {
  renderer = new JsonRenderer {
    converters {
      [Class] = (c) -> if (c != null) SchemaGenerator.generate(c) else null
    }
  }
}