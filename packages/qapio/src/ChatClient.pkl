module Tdip.Qapio.Assistant.ChatClient
extends "Qaplet.pkl"
import "Agent.pkl"
import "Qapi.pkl"

ApiToken: String
Model: String?

function Create(agent: Agent | String): Qapi.FlowStage =
  new Qapi.FlowStage {
    Endpoint = module.Id
    Qapi = "Create"
    Props = if (agent is Agent) agent.Id else agent
  }