open module Tdip.Qapio.Stages.Source.SourceStage

extends "Qaplet.pkl"

import "SourceStage.pkl" as QapiModule

typealias SourceStage = QapiModule.SourceStage

function Tick(interval: Int): SourceStage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "Tick"
    Props = new Dynamic {
      Interval = interval
    }
  })

function CombineLatest(sources: Listing<SourceStage>): SourceStage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "CombineLatest"
    Props = new Dynamic {
      Sources = sources
    }
  })

function FromExpression(expression: String): SourceStage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "FromExpression"
    Props = expression
  })

function From(stage: SourceStage): SourceStage =
  if (stage is SourceStage)
    stage
  else
    new SourceStage {
      Endpoint = stage.Endpoint
      Kind = "Source"
      Qapi = stage.Qapi
      Props = stage.Props
    }

function Single(value: Any): SourceStage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "Single"
    Props = value
  })

Qapi: SourceStage
