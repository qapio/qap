module Tdip.Qapio.Source
extends "Qaplet.pkl"

import "Qapi.pkl" as QapiModule

typealias Stage = QapiModule.Stage
typealias SourceStage = QapiModule.SourceStage

function Tick(interval: Int): Stage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "Tick"
    Props = new Dynamic {
      Interval = interval
    }
  })

function CombineLatest(sources: Listing<Stage>): Stage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "CombineLatest"
    Props = new Dynamic {
      Sources = sources
    }
  })

function FromExpression(expression: String): Stage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "FromExpression"
    Props = expression
  })

function From(stage: Stage): Stage =
  if (stage is SourceStage)
    stage
  else
    new SourceStage {
      Endpoint = stage.Endpoint
      Kind = "Source"
      Qapi = stage.Qapi
      Props = stage.Props
    }

function Single(value: Any): Stage =
  From(new SourceStage {
    Endpoint = "Source"
    Qapi = "Single"
    Props = value
  })

Qapi: Stage
