open module Tdip.Qapio.Qaplet
import "pkl:reflect"

open class Qap {
  Id: String
  Module: String
  Props: Any
}

class ContextData {
  Name: String?
  Description: String?
  Extensions: Listing<Qap>
}

Id: String = reflect.Module(module).name
Context: ContextData = new ContextData {

}

function Uri(fileName: String): Uri = read(fileName).uri